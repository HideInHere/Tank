# ============================================================
# Tank Trading System — Environment Variables
# Copy to .env and fill in real values before running
# ============================================================

# ── Core ──────────────────────────────────────────────────
TZ=UTC
TRADING_ENV=paper

# ── Database ─────────────────────────────────────────────
POSTGRES_USER=tank
POSTGRES_PASSWORD=changeme_postgres

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis

# ── OpenClaw Gateway ─────────────────────────────────────
OPENCLAW_SECRET=changeme_openclaw_secret_32chars_min
OPENCLAW_ADMIN_TOKEN=changeme_admin_token_32chars_min

# ── Tank Agent (AI) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
TANK_AGENT_ID=tank-agent-001
TANK_AGENT_MODE=persistent

# ── Exchange APIs ─────────────────────────────────────────
PAPER_TRADING=true
DEFAULT_EXCHANGE=paper

BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ── Notifications ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8755251450:AAHR5XfLzDYLNs23-a3NkxFgDuN6qSJ7VHg
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ── Observability ─────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_grafana
GRAFANA_PORT=3000

ALERTMANAGER_PORT=9093

# ── Unleash Feature Flags ─────────────────────────────────
UNLEASH_PORT=4242
UNLEASH_SECRET=changeme_unleash_secret

# ── n8n Workflow Orchestration ────────────────────────────
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_n8n

# ── Risk Management ───────────────────────────────────────
RISK_MAX_POSITION_SIZE=10000
RISK_MAX_DAILY_LOSS=5000
RISK_MAX_DRAWDOWN_PCT=15

# ── Backup / GitHub ───────────────────────────────────────
GIT_TOKEN=
GIT_EMAIL=tank-backup@localhost
BACKUP_GITHUB_REPO=https://github.com/yourorg/tank-backups
BACKUP_BRANCH=backups
BACKUP_RETENTION_DAYS=30
